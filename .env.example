# =============================================================================
# SentinalAI — Complete Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Run `GET /api/v1/health/tools` to verify which integrations are connected.
#
# STUB MODE (default): Any tool without its env var will return realistic
# fixture responses. The system runs fully without any real tools.
# LIVE MODE: Set the vars below to connect to real systems.
# =============================================================================


# =============================================================================
# 1. LLM PROVIDER (required for AI-powered RCA, diff analysis, fix generation)
# =============================================================================

# Option A: Anthropic Claude (recommended)
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6            # claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001

# Option B: OpenAI
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# Option C: AWS Bedrock
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# LLM provider selection (anthropic | openai | bedrock)
LLM_PROVIDER=anthropic

# Disable LLM entirely (deterministic mode, no AI reasoning)
# LLM_ENABLED=false


# =============================================================================
# 2. AGENTCORE GATEWAY (central MCP router)
# =============================================================================

# AgentCore endpoint — all MCP tool calls route through this
AGENTCORE_URL=https://your-agentcore.internal:8080

# OAuth2 client credentials for gateway authentication
AGENTCORE_CLIENT_ID=sentinalai-agent
AGENTCORE_CLIENT_SECRET=your-secret-here
AGENTCORE_TOKEN_URL=https://your-auth-server/oauth/token

# Gateway mode: live (real tools) | stub (fixture responses, default)
GATEWAY_MODE=stub


# =============================================================================
# 3. SERVICENOW (CMDB, incident management, change records)
# =============================================================================

SERVICENOW_MCP_URL=https://your-agentcore.internal:8080/mcp/servicenow
SERVICENOW_URL=https://yourinstance.service-now.com
SERVICENOW_USER=sentinalai-integration
SERVICENOW_PASS=your-snow-password

# Optional: ServiceNow OAuth (preferred over basic auth)
# SERVICENOW_CLIENT_ID=...
# SERVICENOW_CLIENT_SECRET=...
# SERVICENOW_OAUTH_URL=https://yourinstance.service-now.com/oauth_token.do


# =============================================================================
# 4. GITHUB (deployment history, code diffs, PR creation for auto-fix)
# =============================================================================

GITHUB_MCP_URL=https://your-agentcore.internal:8080/mcp/github
GITHUB_TOKEN=ghp_...
GITHUB_ORG=your-org

# Service → repo mapping (YAML or JSON, overrides auto-detection)
# GITHUB_REPO_MAP=/etc/sentinalai/repo_map.yaml


# =============================================================================
# 5. SPLUNK (log aggregation, error search, change data)
# =============================================================================

SPLUNK_MCP_URL=https://your-agentcore.internal:8080/mcp/splunk
SPLUNK_URL=https://splunk.internal:8089
SPLUNK_TOKEN=your-splunk-hec-token
SPLUNK_DEFAULT_INDEX=production


# =============================================================================
# 6. SYSDIG (infrastructure metrics, golden signals, Kubernetes events)
# =============================================================================

SYSDIG_MCP_URL=https://your-agentcore.internal:8080/mcp/sysdig
SYSDIG_URL=https://app.sysdig.com
SYSDIG_TOKEN=your-sysdig-api-token
SYSDIG_TEAM_ID=your-team-id


# =============================================================================
# 7. DYNATRACE (APM, distributed tracing, error sampling)
# =============================================================================

DYNATRACE_MCP_URL=https://your-agentcore.internal:8080/mcp/dynatrace
DYNATRACE_URL=https://yourenv.live.dynatrace.com
DYNATRACE_API_TOKEN=dt0c01....


# =============================================================================
# 8. MOOGSOFT (alert correlation, incident intake)
# =============================================================================

MOOGSOFT_MCP_URL=https://your-agentcore.internal:8080/mcp/moogsoft
MOOGSOFT_URL=https://yourinstance.moogsoft.ai
MOOGSOFT_API_KEY=your-moogsoft-key


# =============================================================================
# 9. CONFLUENCE (runbooks, post-mortems, knowledge base)
# =============================================================================

CONFLUENCE_MCP_URL=https://your-agentcore.internal:8080/mcp/confluence
CONFLUENCE_URL=https://yourcompany.atlassian.net/wiki
CONFLUENCE_USER=sentinalai@yourcompany.com
CONFLUENCE_API_TOKEN=your-confluence-token
CONFLUENCE_SPACE_KEY=OPS


# =============================================================================
# 10. KUBERNETES (pod management, rollback, scaling — for auto-fix)
# =============================================================================

KUBERNETES_MCP_URL=https://your-agentcore.internal:8080/mcp/kubernetes
KUBERNETES_CONFIG_PATH=/etc/sentinalai/kubeconfig
KUBERNETES_DEFAULT_NAMESPACE=production


# =============================================================================
# 11. DATABASE (investigation persistence, audit trail)
# =============================================================================

# PostgreSQL (production recommended)
DATABASE_URL=postgresql://sentinalai:password@localhost:5432/sentinalai

# SQLite (development only)
# DATABASE_URL=sqlite:///./sentinalai.db

# DynamoDB (AWS serverless)
# DYNAMODB_TABLE=sentinalai-investigations
# AWS_REGION=us-east-1


# =============================================================================
# 12. AGUI BFF (Backend for Frontend)
# =============================================================================

AGUI_BFF_PORT=8081
AGUI_BFF_HOST=0.0.0.0

# CORS origins (comma-separated)
AGUI_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT secret for API authentication
AGUI_JWT_SECRET=change-this-in-production-to-a-long-random-string
AGUI_JWT_ALGORITHM=HS256
AGUI_JWT_EXPIRY_HOURS=24


# =============================================================================
# 13. AGENT BEHAVIOR TUNING
# =============================================================================

# Parallel playbook execution (faster investigations, default: true)
PARALLEL_PLAYBOOK=true

# Maximum tool calls per investigation (budget guard)
MAX_TOOL_CALLS=20

# Per-investigation wall-clock deadline in seconds
INVESTIGATION_DEADLINE_SECONDS=300

# Maximum concurrent worker threads
MAX_CONCURRENT_WORKERS=8

# Confidence calibration (learns from ground truth feedback)
CONFIDENCE_CALIBRATION_ENABLED=true

# Experience store (RAG over past investigations, default: true)
EXPERIENCE_STORE_ENABLED=true

# Self-critique pass (LLM evaluates its own RCA, default: true)
SELF_CRITIQUE_ENABLED=true

# Knowledge graph (institutional memory, optional)
KNOWLEDGE_GRAPH_ENABLED=false


# =============================================================================
# 14. CODE WORKER (AI diff analysis + fix generation)
# =============================================================================

# Minimum confidence before the code worker generates a fix recommendation
CODE_WORKER_MIN_CONFIDENCE=60

# Maximum diff size passed to LLM (prevents token blow-up)
CODE_WORKER_MAX_DIFF_CHARS=8000


# =============================================================================
# 15. VERIFICATION LOOP (post-fix service stability check)
# =============================================================================

# Seconds between stability polls after fix is applied (default: 60)
VERIFICATION_POLL_INTERVAL_SEC=60

# Maximum poll attempts before declaring failure (default: 10 = 10 min)
VERIFICATION_MAX_POLLS=10

# Consecutive stable readings required for success (default: 3)
VERIFICATION_STABLE_THRESHOLD=3


# =============================================================================
# 16. OBSERVABILITY (OpenTelemetry tracing, metrics)
# =============================================================================

# OTLP endpoint (Jaeger, Honeycomb, Grafana Tempo, etc.)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=sentinalai
OTEL_TRACES_EXPORTER=otlp    # otlp | console | none

# Prometheus metrics
PROMETHEUS_METRICS_PORT=9090
PROMETHEUS_METRICS_ENABLED=false


# =============================================================================
# 17. SECURITY
# =============================================================================

# Honeypot: invite-only access (prevents unauthorized use)
HONEYPOT_ENABLED=false
HONEYPOT_INVITE_TOKEN=change-this-long-random-token

# Rate limiting (requests per minute per actor)
RATE_LIMIT_RPM=60

# Audit log destination
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=/var/log/sentinalai/audit.log
