# =========================================================================
# SentinalAI Environment Configuration
# Copy to .env and fill in actual values before deployment.
# Everything runs in a single Docker image — just set these variables.
# =========================================================================

# ----- AI / LLM (AWS Bedrock) -----
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v1:0
EVAL_JUDGE_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
LLM_ENABLED=true
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# ----- MCP Tool ARNs (AgentCore Runtime Engines) -----
# When unset, workers return stub responses for local dev / testing.
# MCP_MOOGSOFT_TOOL_ARN=arn:aws:bedrock:us-east-1:123456789:agent-runtime/moogsoft
# MCP_SPLUNK_TOOL_ARN=arn:aws:bedrock:us-east-1:123456789:agent-runtime/splunk
# MCP_SYSDIG_TOOL_ARN=arn:aws:bedrock:us-east-1:123456789:agent-runtime/sysdig
# MCP_SIGNALFX_TOOL_ARN=arn:aws:bedrock:us-east-1:123456789:agent-runtime/signalfx
# MCP_DYNATRACE_TOOL_ARN=arn:aws:bedrock:us-east-1:123456789:agent-runtime/dynatrace
# MCP_SERVICENOW_TOOL_ARN=arn:aws:bedrock:us-east-1:123456789:agent-runtime/servicenow
# MCP_GITHUB_TOOL_ARN=arn:aws:bedrock:us-east-1:123456789:agent-runtime/github
MCP_CALL_TIMEOUT_SECONDS=30
MCP_MAX_RETRIES=2

# ----- AgentCore Gateway (preferred — single endpoint for all MCP targets) -----
# When set, individual MCP_*_TOOL_ARN values are ignored (gateway handles routing).
# AGENTCORE_GATEWAY_URL=https://gateway.agentcore.us-east-1.amazonaws.com
# AGENTCORE_TARGET_MOOGSOFT=MoogsoftTarget
# AGENTCORE_TARGET_SPLUNK=SplunkTarget
# AGENTCORE_TARGET_SYSDIG=SysdigTarget
# AGENTCORE_TARGET_SIGNALFX=SignalFxTarget
# AGENTCORE_TARGET_DYNATRACE=DynatraceTarget
# AGENTCORE_TARGET_SERVICENOW=ServiceNowTarget
# AGENTCORE_TARGET_GITHUB=GitHubTarget

# ----- OAuth2 Authentication (client_credentials grant for gateway) -----
# GATEWAY_OAUTH2_CLIENT_ID=
# GATEWAY_OAUTH2_CLIENT_SECRET=
# GATEWAY_OAUTH2_TOKEN_URL=https://your-domain.auth.us-east-1.amazoncognito.com/oauth2/token
# GATEWAY_OAUTH2_SCOPE=
# GATEWAY_OAUTH2_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789:secret:gateway-oauth2
# GATEWAY_TOKEN_REFRESH_BUFFER_SECONDS=600
# GATEWAY_ACCESS_TOKEN=

# ----- Database (PostgreSQL + pgvector — optional) -----
# DATABASE_URL=postgresql://sentinalai:changeme@localhost:5432/sentinalai
# DATABASE_POOL_SIZE=10
# DATABASE_POOL_OVERFLOW=5
# DATABASE_POOL_TIMEOUT=30
# DATABASE_POOL_RECYCLE=1800

# ----- Investigation Settings -----
MAX_INVESTIGATION_TIME_SECONDS=60
INVESTIGATION_BUDGET_MAX_CALLS=20
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_SECONDS=60

# ----- Observability (Splunk HEC — OTEL collector is embedded in the image) -----
# Set both SPLUNK_HEC_TOKEN and SPLUNK_HEC_ENDPOINT to enable the built-in
# OTEL collector.  The agent's OTEL_EXPORTER_OTLP_ENDPOINT is automatically
# set to http://127.0.0.1:4318 (local collector).  Override the variable
# below only if you want to point at an external collector instead.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# SPLUNK_HEC_TOKEN=changeme
# SPLUNK_HEC_ENDPOINT=https://splunk.internal:8088/services/collector
SPLUNK_HEC_INSECURE=false
SPLUNK_TRACES_INDEX=traces
SPLUNK_METRICS_INDEX=metrics
SPLUNK_LOGS_INDEX=main
OTEL_DEPLOYMENT_ENV=dev

# ----- AgentCore Memory (STM + LTM) -----
# BEDROCK_AGENTCORE_MEMORY_ID=
MEMORY_STM_LAST_K_TURNS=5
MEMORY_LTM_TOP_K=3
MEMORY_LTM_RELEVANCE_THRESHOLD=0.5

# ----- Institutional Knowledge Graph -----
KNOWLEDGE_GRAPH_ENABLED=false
KNOWLEDGE_STORAGE_DIR=knowledge/.knowledge_store

# ----- Runtime -----
LOG_LEVEL=INFO
